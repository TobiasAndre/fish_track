<%= form_with model: @batch, local: true do |f| %>
  <div class="space-y-6">
    <% if @batch.errors.any? %>
      <div class="rounded-lg border border-red-300 bg-red-50 px-4 py-3 text-sm text-red-700 dark:border-red-800 dark:bg-red-950 dark:text-red-300">
        <p class="font-semibold mb-2">Não foi possível salvar o lote:</p>
        <ul class="list-disc pl-5 space-y-1">
          <% @batch.errors.full_messages.each do |message| %>
            <li><%= message %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <div class="grid grid-cols-1 gap-4 sm:grid-cols-2">
      <div>
        <%= f.label :name, "Nome do lote", class: "block text-sm font-medium text-gray-700 dark:text-gray-300" %>
        <div class="mt-1">
          <%= f.text_field :name,
            class: "w-full rounded-lg border px-3 py-2 text-sm
                    bg-white dark:bg-gray-950
                    border-gray-300 dark:border-gray-700
                    text-gray-900 dark:text-gray-100
                    focus:outline-none focus:ring-2 focus:ring-indigo-500" %>
        </div>
      </div>

      <div>
        <%= f.label :product_id, "Produto", class: "block text-sm font-medium text-gray-700 dark:text-gray-300" %>
        <div class="mt-1">
          <%= f.collection_select :product_id, @products, :id, :name,
            { prompt: "Selecione um produto" },
            class: "w-full rounded-lg border px-3 py-2 text-sm
                    bg-white dark:bg-gray-950
                    border-gray-300 dark:border-gray-700
                    text-gray-900 dark:text-gray-100
                    focus:outline-none focus:ring-2 focus:ring-indigo-500" %>
        </div>
      </div>
    </div>

    <div class="grid grid-cols-1 gap-4 sm:grid-cols-3">
      <div>
        <%= f.label :started_on, "Data de início do lote", class: "block text-sm font-medium text-gray-700 dark:text-gray-300" %>
        <div class="mt-1">
          <%= f.date_field :started_on,
            class: "w-full rounded-lg border px-3 py-2 text-sm
                    bg-white dark:bg-gray-950
                    border-gray-300 dark:border-gray-700
                    text-gray-900 dark:text-gray-100
                    focus:outline-none focus:ring-2 focus:ring-indigo-500" %>
        </div>
      </div>

      <div>
        <%= f.label :stage, "Fase", class: "block text-sm font-medium text-gray-700 dark:text-gray-300" %>
        <div class="mt-1">
          <%= f.select :stage,
            Batch.stages.keys.map { |k| [enum_t(@batch, :stage, value: k), k] },
            {},
            class: "w-full rounded-lg border px-3 py-2 text-sm
                    bg-white dark:bg-gray-950
                    border-gray-300 dark:border-gray-700
                    text-gray-900 dark:text-gray-100
                    focus:outline-none focus:ring-2 focus:ring-indigo-500" %>
        </div>
      </div>

      <div>
        <%= f.label :status, "Status", class: "block text-sm font-medium text-gray-700 dark:text-gray-300" %>
        <div class="mt-1">
          <%= f.select :status,
            Batch.statuses.keys.map { |k| [enum_t(@batch, :status, value: k), k] },
            {},
            class: "w-full rounded-lg border px-3 py-2 text-sm
                    bg-white dark:bg-gray-950
                    border-gray-300 dark:border-gray-700
                    text-gray-900 dark:text-gray-100
                    focus:outline-none focus:ring-2 focus:ring-indigo-500" %>
        </div>
      </div>
    </div>

    <div
      class="rounded-xl border border-gray-200 dark:border-gray-800 bg-white dark:bg-gray-900 p-4"
      data-controller="nested-form"
    >
      <div class="flex items-start justify-between gap-4">
        <div>
          <h3 class="text-sm font-semibold text-gray-900 dark:text-gray-100">Alojamentos do lote</h3>
          <p class="mt-1 text-xs text-gray-500 dark:text-gray-400">
            Informe em quais tanques o lote foi alojado, com quantidade, data, peso médio e fornecedor.
          </p>
        </div>

        <button
          type="button"
          data-action="nested-form#add"
          class="px-4 py-2 rounded-lg bg-indigo-600 hover:bg-indigo-700 text-white text-sm font-medium transition"
        >
          Adicionar
        </button>
      </div>

      <template data-nested-form-target="template">
        <%= f.fields_for :batch_stockings, BatchStocking.new(stocked_on: Date.current), child_index: "NEW_RECORD" do |stocking_form| %>
          <div class="mt-4 rounded-lg border border-gray-200 dark:border-gray-800 p-4" data-nested-form-wrapper>
            <%= stocking_form.hidden_field :_destroy, value: "0" %>

            <div class="grid grid-cols-1 gap-4 md:grid-cols-2 xl:grid-cols-12">
              <div class="xl:col-span-3">
                <%= stocking_form.label :pond_id, "Tanque", class: "block text-sm font-medium text-gray-700 dark:text-gray-300" %>
                <div class="mt-1">
                  <%= stocking_form.collection_select :pond_id, @ponds, :id, :name,
                    { prompt: "Selecione um tanque" },
                    class: "w-full rounded-lg border px-3 py-2 text-sm
                            bg-white dark:bg-gray-950
                            border-gray-300 dark:border-gray-700
                            text-gray-900 dark:text-gray-100
                            focus:outline-none focus:ring-2 focus:ring-indigo-500" %>
                </div>
              </div>

              <div class="xl:col-span-2">
                <%= stocking_form.label :quantity, "Quantidade", class: "block text-sm font-medium text-gray-700 dark:text-gray-300" %>
                <div class="mt-1">
                  <%= stocking_form.number_field :quantity,
                    min: 1,
                    class: "w-full rounded-lg border px-3 py-2 text-sm
                            bg-white dark:bg-gray-950
                            border-gray-300 dark:border-gray-700
                            text-gray-900 dark:text-gray-100
                            focus:outline-none focus:ring-2 focus:ring-indigo-500" %>
                </div>
              </div>

              <div class="xl:col-span-2">
                <%= stocking_form.label :stocked_on, "Data do alojamento", class: "block text-sm font-medium text-gray-700 dark:text-gray-300" %>
                <div class="mt-1">
                  <%= stocking_form.date_field :stocked_on,
                    class: "w-full rounded-lg border px-3 py-2 text-sm
                            bg-white dark:bg-gray-950
                            border-gray-300 dark:border-gray-700
                            text-gray-900 dark:text-gray-100
                            focus:outline-none focus:ring-2 focus:ring-indigo-500" %>
                </div>
              </div>

              <div class="xl:col-span-1">
                <%= stocking_form.label :avg_weight_g, "Peso (g)", class: "block text-sm font-medium text-gray-700 dark:text-gray-300" %>
                <div class="mt-1">
                  <%= stocking_form.number_field :avg_weight_g,
                    step: 0.01,
                    min: 0,
                    class: "w-full rounded-lg border px-3 py-2 text-sm
                            bg-white dark:bg-gray-950
                            border-gray-300 dark:border-gray-700
                            text-gray-900 dark:text-gray-100
                            focus:outline-none focus:ring-2 focus:ring-indigo-500" %>
                </div>
              </div>

              <div class="xl:col-span-4">
                <%= stocking_form.label :supplier_id, "Fornecedor", class: "block text-sm font-medium text-gray-700 dark:text-gray-300" %>
                <div class="mt-1">
                  <%= stocking_form.collection_select :supplier_id, @suppliers, :id, :name,
                    { prompt: "Selecione um fornecedor" },
                    class: "w-full rounded-lg border px-3 py-2 text-sm
                            bg-white dark:bg-gray-950
                            border-gray-300 dark:border-gray-700
                            text-gray-900 dark:text-gray-100
                            focus:outline-none focus:ring-2 focus:ring-indigo-500" %>
                </div>
              </div>
            </div>

            <div class="mt-4 flex justify-end">
              <button
                type="button"
                data-action="nested-form#remove"
                class="px-3 py-1.5 rounded-lg bg-red-600 hover:bg-red-700 text-white text-sm transition"
              >
                Remover
              </button>
            </div>
          </div>
        <% end %>
      </template>

      <div class="mt-4 space-y-4" data-nested-form-target="container">
        <%= f.fields_for :batch_stockings do |stocking_form| %>
          <div class="rounded-lg border border-gray-200 dark:border-gray-800 p-4" data-nested-form-wrapper>
            <%= stocking_form.hidden_field :_destroy, value: "0" %>

            <div class="grid grid-cols-1 gap-4 md:grid-cols-2 xl:grid-cols-12">
              <div class="xl:col-span-3">
                <%= stocking_form.label :pond_id, "Tanque", class: "block text-sm font-medium text-gray-700 dark:text-gray-300" %>
                <div class="mt-1">
                  <%= stocking_form.collection_select :pond_id, @ponds, :id, :name,
                    { prompt: "Selecione um tanque" },
                    class: "w-full rounded-lg border px-3 py-2 text-sm
                            bg-white dark:bg-gray-950
                            border-gray-300 dark:border-gray-700
                            text-gray-900 dark:text-gray-100
                            focus:outline-none focus:ring-2 focus:ring-indigo-500" %>
                </div>
              </div>

              <div class="xl:col-span-2">
                <%= stocking_form.label :quantity, "Quantidade", class: "block text-sm font-medium text-gray-700 dark:text-gray-300" %>
                <div class="mt-1">
                  <%= stocking_form.number_field :quantity,
                    min: 1,
                    class: "w-full rounded-lg border px-3 py-2 text-sm
                            bg-white dark:bg-gray-950
                            border-gray-300 dark:border-gray-700
                            text-gray-900 dark:text-gray-100
                            focus:outline-none focus:ring-2 focus:ring-indigo-500" %>
                </div>
              </div>

              <div class="xl:col-span-2">
                <%= stocking_form.label :stocked_on, "Data do alojamento", class: "block text-sm font-medium text-gray-700 dark:text-gray-300" %>
                <div class="mt-1">
                  <%= stocking_form.date_field :stocked_on,
                    class: "w-full rounded-lg border px-3 py-2 text-sm
                            bg-white dark:bg-gray-950
                            border-gray-300 dark:border-gray-700
                            text-gray-900 dark:text-gray-100
                            focus:outline-none focus:ring-2 focus:ring-indigo-500" %>
                </div>
              </div>

              <div class="xl:col-span-1">
                <%= stocking_form.label :avg_weight_g, "Peso (g)", class: "block text-sm font-medium text-gray-700 dark:text-gray-300" %>
                <div class="mt-1">
                  <%= stocking_form.number_field :avg_weight_g,
                    step: 0.01,
                    min: 0,
                    class: "w-full rounded-lg border px-3 py-2 text-sm
                            bg-white dark:bg-gray-950
                            border-gray-300 dark:border-gray-700
                            text-gray-900 dark:text-gray-100
                            focus:outline-none focus:ring-2 focus:ring-indigo-500" %>
                </div>
              </div>

              <div class="xl:col-span-4">
                <%= stocking_form.label :supplier_id, "Fornecedor", class: "block text-sm font-medium text-gray-700 dark:text-gray-300" %>
                <div class="mt-1">
                  <%= stocking_form.collection_select :supplier_id, @suppliers, :id, :name,
                    { prompt: "Selecione um fornecedor" },
                    class: "w-full rounded-lg border px-3 py-2 text-sm
                            bg-white dark:bg-gray-950
                            border-gray-300 dark:border-gray-700
                            text-gray-900 dark:text-gray-100
                            focus:outline-none focus:ring-2 focus:ring-indigo-500" %>
                </div>
              </div>
            </div>

            <div class="mt-4 flex justify-end">
              <button
                type="button"
                data-action="nested-form#remove"
                class="px-3 py-1.5 rounded-lg bg-red-600 hover:bg-red-700 text-white text-sm transition"
              >
                Remover
              </button>
            </div>
          </div>
        <% end %>
      </div>
    </div>

    <div class="flex items-center justify-end gap-4">
      <%= link_to "Cancelar", batches_path, class: "text-sm text-gray-500 hover:text-gray-700 dark:text-gray-400 dark:hover:text-gray-200" %>
      <%= f.submit @batch.persisted? ? "Atualizar lote" : "Criar lote",
        class: "inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md shadow-sm text-white bg-indigo-600 hover:bg-indigo-700" %>
    </div>
  </div>
<% end %>
