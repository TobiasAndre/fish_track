<div class="max-w-7xl mx-auto">
  <div class="flex items-center justify-between">
    <div>
      <h1 class="text-2xl font-semibold text-gray-900 dark:text-gray-100">Lotes</h1>
      <p class="mt-1 text-sm text-gray-600 dark:text-gray-300">
        Gerencie lotes por tanque e acompanhe seus alojamentos.
      </p>
    </div>

    <%= link_to "Novo lote", new_batch_path,
      class: "px-4 py-2 rounded-lg bg-indigo-600 hover:bg-indigo-700
              dark:bg-indigo-500 dark:hover:bg-indigo-400
              text-white text-sm font-medium transition" %>
  </div>

  <div class="mt-6 overflow-hidden rounded-xl border border-gray-200 dark:border-gray-800 bg-white dark:bg-gray-900">
    <table class="w-full text-sm">
      <thead class="bg-gray-50 dark:bg-gray-950/40 text-gray-600 dark:text-gray-300">
        <tr>
          <th class="text-left px-4 py-3 font-medium">Lote</th>
          <th class="text-left px-4 py-3 font-medium">Fase</th>
          <th class="text-left px-4 py-3 font-medium">Status</th>
          <th class="text-left px-4 py-3 font-medium">Início</th>
          <th class="text-right px-4 py-3 font-medium">Ações</th>
        </tr>
      </thead>

      <tbody class="divide-y divide-gray-200 dark:divide-gray-800">
        <% @batches.each do |batch| %>
          <tr class="bg-white dark:bg-gray-900">
            <td class="px-4 py-4 align-top">
              <%= link_to batch.name, batch_path(batch),
                class: "font-medium text-gray-900 dark:text-gray-100 hover:underline" %>

              <% if batch.species.present? %>
                <div class="text-xs text-gray-500 dark:text-gray-400 mt-1">
                  <%= batch.species %>
                </div>
              <% end %>

              <% if batch.product.present? %>
                <div class="text-xs text-gray-500 dark:text-gray-400 mt-1">
                  Produto: <%= batch.product.name %>
                </div>
              <% end %>
            </td>

            <td class="px-4 py-4 text-gray-700 dark:text-gray-200 align-top">
              <%= enum_t(batch, :stage) %>
            </td>

            <td class="px-4 py-4 align-top">
              <% badge = batch.active_status? ? "bg-green-100 text-green-800 dark:bg-green-950/40 dark:text-green-300" : "bg-gray-100 text-gray-800 dark:bg-gray-800 dark:text-gray-200" %>
              <span class="inline-flex items-center px-2 py-1 rounded-lg text-xs font-medium <%= badge %>">
                <%= enum_t(batch, :status) %>
              </span>
            </td>

            <td class="px-4 py-4 text-gray-700 dark:text-gray-200 align-top">
              <%= l(batch.started_on) %>
            </td>

            <td class="px-4 py-4 align-top">
              <div class="flex justify-end gap-2">
                <%= link_to "Editar", edit_batch_path(batch),
                  class: "px-3 py-1.5 rounded-lg border border-gray-300 dark:border-gray-700
                          hover:bg-gray-50 dark:hover:bg-gray-800 transition" %>

                <%= button_to "Excluir", batch_path(batch),
                  method: :delete,
                  data: { turbo_confirm: "Excluir lote #{batch.name}?" },
                  class: "px-3 py-1.5 rounded-lg bg-red-600 hover:bg-red-700 text-white transition" %>
              </div>
            </td>
          </tr>

          <tr class="bg-gray-50/70 dark:bg-gray-950/30">
            <td colspan="5" class="px-4 pb-4">
              <div class="mt-4 overflow-hidden rounded-lg border border-gray-200 dark:border-gray-800 bg-white dark:bg-gray-900">
                <table class="w-full text-sm">
                  <thead class="bg-gray-50 dark:bg-gray-950/40 text-gray-500 dark:text-gray-400">
                    <tr>
                      <th class="text-left px-4 py-2 font-medium">Unidade</th>
                      <th class="text-left px-4 py-2 font-medium">Tanque</th>
                      <th class="text-left px-4 py-2 font-medium">Quantidade</th>
                      <th class="text-left px-4 py-2 font-medium">Alojamento</th>
                      <th class="text-left px-4 py-2 font-medium">Peso médio</th>
                      <th class="text-left px-4 py-2 font-medium">Peixes m²</th>
                      <th class="text-left px-4 py-2 font-medium">Fornecedor</th>
                      <th class="text-right px-4 py-2 font-medium">Eventos</th>
                    </tr>
                  </thead>

                  <tbody class="divide-y divide-gray-200 dark:divide-gray-800">
                    <% batch.batch_stockings.each do |stocking| %>
                      <tr>
                        <td class="px-4 py-3 text-gray-700 dark:text-gray-200">
                          <%= stocking.pond.unit.name %>
                        </td>

                        <td class="px-4 py-3 text-gray-700 dark:text-gray-200">
                          <%= stocking.pond.name %>
                        </td>

                        <td class="px-4 py-3 text-gray-700 dark:text-gray-200">
                          <%= stocking.quantity.present? ? number_with_delimiter(stocking.quantity, delimiter: ".") : "—" %>
                        </td>

                        <td class="px-4 py-3 text-gray-700 dark:text-gray-200">
                          <%= l(stocking.stocked_on) %>
                        </td>

                        <td class="px-4 py-3 text-gray-700 dark:text-gray-200">
                          <%= stocking.avg_weight_g.present? ? "#{stocking.avg_weight_g} g" : "—" %>
                        </td>

                        <td class="px-4 py-3 text-gray-700 dark:text-gray-200">
                          <% fish_per_m2 = stocking.quantity / (stocking.pond.capacity || 1) %>

                          <%= fish_per_m2.present? ? fish_per_m2 : "—" %>
                        </td>

                        <td class="px-4 py-3 text-gray-700 dark:text-gray-200">
                          <%= stocking.supplier&.name || "—" %>
                        </td>

                        <td class="px-4 py-3">
                          <div class="flex justify-end">
                            <%= link_to "Eventos",
                              batch_batch_stocking_stocking_events_path(batch, stocking),
                              class: "px-3 py-1.5 rounded-lg border border-gray-300 dark:border-gray-700
                                      hover:bg-gray-50 dark:hover:bg-gray-800 transition" %>
                          </div>
                        </td>
                      </tr>
                    <% end %>

                    <% if batch.batch_stockings.empty? %>
                      <tr>
                        <td colspan="7" class="px-4 py-4 text-center text-sm text-gray-500 dark:text-gray-400">
                          Nenhum alojamento cadastrado para este lote.
                        </td>
                      </tr>
                    <% end %>
                  </tbody>
                </table>
              </div>
            </td>
          </tr>
        <% end %>

        <% if @batches.empty? %>
          <tr>
            <td colspan="5" class="px-4 py-6 text-center text-sm text-gray-500 dark:text-gray-400">
              Nenhum lote encontrado.
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>

  <% if @batches.respond_to?(:total_count) && @batches.total_count > 0 %>
    <div class="mt-4 flex flex-col items-center gap-2">
      <p class="text-sm text-gray-600 dark:text-gray-300">
        Mostrando <%= @batches.offset_value + 1 %>–
        <%= [@batches.offset_value + @batches.limit_value, @batches.total_count].min %>
        de <%= @batches.total_count %> lotes
      </p>

      <%= paginate @batches %>
    </div>
  <% end %>
</div>
