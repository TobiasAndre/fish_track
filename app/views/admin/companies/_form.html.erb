<%= form_with model: [:admin, company], local: true do |form| %>
  <div class="space-y-6">
    <% if company.errors.any? %>
      <div class="rounded-lg border border-red-300 bg-red-50 px-4 py-3 text-sm text-red-700 dark:border-red-800 dark:bg-red-950 dark:text-red-300">
        <p class="font-semibold mb-2">Não foi possível salvar a empresa:</p>
        <ul class="list-disc pl-5 space-y-1">
          <% company.errors.full_messages.each do |message| %>
            <li><%= message %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <div>
      <%= form.label :name, "Nome da empresa", class: "block text-sm font-medium text-gray-700 dark:text-gray-300" %>
      <div class="mt-1">
        <%= form.text_field :name,
          class: "w-full rounded-lg border px-3 py-2 text-sm
                  bg-white dark:bg-gray-950
                  border-gray-300 dark:border-gray-700
                  text-gray-900 dark:text-gray-100
                  focus:outline-none focus:ring-2 focus:ring-indigo-500" %>
      </div>
    </div>

    <div>
      <%= form.label :tenant_name, "Nome do tenant/schema", class: "block text-sm font-medium text-gray-700 dark:text-gray-300" %>
      <div class="mt-1">
        <%= form.text_field :tenant_name,
          placeholder: "empresa_x",
          class: "w-full rounded-lg border px-3 py-2 text-sm
                  bg-white dark:bg-gray-950
                  border-gray-300 dark:border-gray-700
                  text-gray-900 dark:text-gray-100
                  focus:outline-none focus:ring-2 focus:ring-indigo-500" %>
      </div>
      <p class="mt-1 text-xs text-gray-500 dark:text-gray-400">
        Use apenas letras minúsculas, números e underscore.
      </p>
    </div>

    <% unless company.persisted? %>
      <div>
        <%= form.label :owner_user_id, "Usuário responsável", class: "block text-sm font-medium text-gray-700 dark:text-gray-300" %>
        <div class="mt-1">
          <%= form.collection_select :owner_user_id, @users, :id, :email,
            { prompt: "Selecione um usuário" },
            class: "w-full rounded-lg border px-3 py-2 text-sm
                    bg-white dark:bg-gray-950
                    border-gray-300 dark:border-gray-700
                    text-gray-900 dark:text-gray-100
                    focus:outline-none focus:ring-2 focus:ring-indigo-500" %>
        </div>
      </div>
    <% end %>

    <div class="flex items-center justify-end gap-4">
      <%= link_to "Cancelar", admin_companies_path, class: "text-sm text-gray-500 hover:text-gray-700 dark:text-gray-400 dark:hover:text-gray-200" %>
      <%= form.submit company.persisted? ? "Atualizar" : "Salvar",
        class: "inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md shadow-sm text-white bg-indigo-600 hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500" %>
    </div>
  </div>
<% end %>
