<div class="max-w-4xl mx-auto space-y-6">
  <div class="flex items-start justify-between gap-4">
    <!-- Título -->
    <div>
      <h1 class="text-2xl font-semibold text-gray-900 dark:text-gray-100">
        Editar orçamento
      </h1>
      <p class="mt-1 text-sm text-gray-500 dark:text-gray-400">
        Atualize os dados da simulação.
      </p>
    </div>

    <!-- Botões alinhados à direita -->
    <div class="flex items-center gap-2">
      <% company = Company.find_by(tenant_name: session[:tenant_name]) %>

      <% mensagem = "Orçamento #{company&.name}: #{@simulation.customer.name}" %>
      <% url = shared_simulation_pdf_url(
        tenant_name: session[:tenant_name],
        id: @simulation.id,
        share_token: @simulation.share_token,
        format: :pdf
      ) %>

      <%= link_to "https://wa.me/?text=#{CGI.escape("#{mensagem} #{url}")}",
            target: "_blank",
            rel: "noopener",
            title: "Compartilhar no WhatsApp",
            class: "inline-flex items-center justify-center rounded-lg bg-green-500 p-2 text-white hover:bg-green-600 transition" do %>
        <i class="fa-brands fa-whatsapp text-xl"></i>
      <% end %>

      <%= link_to "Imprimir", print_simulation_path(@simulation, format: :pdf),
        target: "_blank",
        rel: "noopener",
        class: "px-4 py-2 rounded-lg border border-gray-300 dark:border-gray-700
                hover:bg-gray-50 dark:hover:bg-gray-800 transition text-sm" %>
    </div>
  </div>

  <div class="rounded-xl border border-gray-200 bg-white p-6 shadow-sm dark:border-gray-800 dark:bg-gray-900">
    <%= render "form" %>
  </div>
</div>
