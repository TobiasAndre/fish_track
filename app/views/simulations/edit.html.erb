<div class="max-w-4xl mx-auto space-y-6">
  <div class="flex items-start justify-between gap-4">
    <div>
      <h1 class="text-2xl font-semibold text-gray-900 dark:text-gray-100">Editar orçamento</h1>
      <p class="mt-1 text-sm text-gray-500 dark:text-gray-400">
        Atualize os dados da simulação.
      </p>
    </div>

    <%= link_to "Imprimir", print_simulation_path(@simulation),
      target: "_blank",
      rel: "noopener",
      class: "px-4 py-2 rounded-lg border border-gray-300 dark:border-gray-700
              hover:bg-gray-50 dark:hover:bg-gray-800 transition text-sm" %>
  </div>

  <div class="rounded-xl border border-gray-200 bg-white p-6 shadow-sm dark:border-gray-800 dark:bg-gray-900">
    <%= render "form" %>
  </div>
</div>
