<div class="max-w-7xl mx-auto">
  <div class="flex items-center justify-between">
    <div>
      <h1 class="text-2xl font-semibold text-gray-900 dark:text-gray-100">Orçamentos</h1>
      <p class="mt-1 text-sm text-gray-500 dark:text-gray-400">
        Gerencie os orçamentos cadastrados.
      </p>
    </div>

    <%= link_to "Novo orçamento", new_simulation_path,
      class: "inline-flex items-center rounded-lg bg-indigo-600 px-4 py-2 text-sm font-medium text-white hover:bg-indigo-700" %>
  </div>

  <div class="overflow-hidden rounded-xl border border-gray-200 bg-white shadow-sm dark:border-gray-800 dark:bg-gray-900">
    <div class="overflow-x-auto">
      <table class="min-w-full divide-y divide-gray-200 dark:divide-gray-800">
        <thead class="bg-gray-50 dark:bg-gray-950">
          <tr>
            <th class="px-4 py-3 text-left text-xs font-semibold uppercase tracking-wider text-gray-500 dark:text-gray-400">
              Cliente
            </th>
            <th class="px-4 py-3 text-left text-xs font-semibold uppercase tracking-wider text-gray-500 dark:text-gray-400">
              Data
            </th>
            <th class="px-4 py-3 text-left text-xs font-semibold uppercase tracking-wider text-gray-500 dark:text-gray-400">
              Quantidade
            </th>
            <th class="px-4 py-3 text-left text-xs font-semibold uppercase tracking-wider text-gray-500 dark:text-gray-400">
              Peso total
            </th>
            <th class="px-4 py-3 text-left text-xs font-semibold uppercase tracking-wider text-gray-500 dark:text-gray-400">
              Valor total
            </th>
            <th class="px-4 py-3 text-right text-xs font-semibold uppercase tracking-wider text-gray-500 dark:text-gray-400">
              Ações
            </th>
          </tr>
        </thead>

        <tbody class="divide-y divide-gray-200 dark:divide-gray-800">
          <% @simulations.each do |simulation| %>
            <tr>
              <td class="px-4 py-3 text-sm text-gray-900 dark:text-gray-100">
                <%= simulation.customer.name %>
              </td>
              <td class="px-4 py-3 text-sm text-gray-600 dark:text-gray-300">
                <%= l(simulation.simulated_on) %>
              </td>
              <td class="px-4 py-3 text-sm text-gray-600 dark:text-gray-300">
                <%= simulation.quantity.present? ? number_with_delimiter(simulation.quantity, delimiter: ".") : "—" %>
              </td>
              <td class="px-4 py-3 text-sm text-gray-600 dark:text-gray-300">
                <%= simulation.total_weight_kg %> kg
              </td>
              <td class="px-4 py-3 text-sm text-gray-600 dark:text-gray-300">
                <%= number_to_currency(simulation.total_cents.to_i / 100.0) %>
              </td>
              <td class="px-4 py-3 text-right text-sm">
                <div class="flex items-center justify-end gap-3">
                  <%= link_to "Imprimir", print_simulation_path(simulation),
                    target: "_blank",
                    rel: "noopener",
                    class: "text-gray-600 hover:text-gray-800 dark:text-gray-300 dark:hover:text-gray-100" %>

                  <%= link_to "Editar", edit_simulation_path(simulation),
                    class: "text-indigo-600 hover:text-indigo-800 dark:text-indigo-400 dark:hover:text-indigo-300" %>

                  <%= link_to "Excluir", simulation_path(simulation),
                    data: { turbo_method: :delete, turbo_confirm: "Tem certeza que deseja excluir esta simulação?" },
                    class: "text-red-600 hover:text-red-800 dark:text-red-400 dark:hover:text-red-300" %>
                </div>
              </td>
            </tr>
          <% end %>

          <% if @simulations.empty? %>
            <tr>
              <td colspan="6" class="px-4 py-6 text-center text-sm text-gray-500 dark:text-gray-400">
                Nenhum orçamento encontrado.
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>

  <% if @simulations.respond_to?(:total_count) && @simulations.total_count > 0 %>
    <div class="mt-4 flex flex-col items-center gap-2">
      <p class="text-sm text-gray-600 dark:text-gray-300">
        Mostrando <%= @simulations.offset_value + 1 %>–
        <%= [@simulations.offset_value + @simulations.limit_value, @simulations.total_count].min %>
        de <%= @simulations.total_count %> orçamentos
      </p>

      <%= paginate @simulations %>
    </div>
  <% end %>
</div>
