<% company = Company.find_by(tenant_name: session[:tenant_name]) %>

<div class="actions">
  <button onclick="window.print()">Imprimir</button>
</div>

<div class="header" style="display: flex; justify-content: space-between; align-items: flex-start;">
  <div>
    <h1 class="title">Orçamento</h1>
    <div class="subtitle">
      Cliente: <strong><%= @simulation.customer.name %></strong><br>
      Data: <strong><%= l(@simulation.simulated_on) %></strong>
    </div>
  </div>

  <% if company.logo_url.present? %>
    <div style="text-align: right;">
      <img
        src="<%= company.logo_url %>"
        alt="Logomarca"
        style="max-height: 80px; max-width: 200px;"
      >
    </div>
  <% end %>
</div>

<% if @simulation.products.any? %>
  <div class="section" style="margin-bottom: 24px;">
    <div class="section-title">Produtos do orçamento</div>

    <table>
      <tbody>
        <% @simulation.products.each do |product| %>
          <tr>
            <th style="width: 70%"><%= product.name %></th>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
<% end %>

<div class="grid">
  <div class="card">
    <div class="label">Quantidade</div>
    <div class="value"><%= number_with_delimiter(@simulation.quantity, delimiter: ".") %></div>
  </div>

  <div class="card">
    <div class="label">Peso médio (kg)</div>
    <div class="value"><%= number_with_precision(@simulation.avg_weight_kg, precision: 3, separator: ",", delimiter: ".") %></div>
  </div>

  <div class="card">
    <div class="label">Peso total (kg)</div>
    <div class="value"><%= number_with_precision(@simulation.total_weight_kg, precision: 3, separator: ",", delimiter: ".") %></div>
  </div>

  <div class="card">
    <div class="label">Quantidade de viagens</div>
    <div class="value"><%= @simulation.loading_count %></div>
  </div>
</div>

<div class="section">
  <div class="section-title">Composição dos valores</div>

  <table>
    <tbody>
      <tr>
        <th>Preço por kg</th>
        <td><%= number_to_currency(@simulation.price_per_kg_cents.to_i / 100.0) %></td>
      </tr>
      <tr>
        <th>Valor do carregamento</th>
        <td><%= number_to_currency(@simulation.loading_cost_cents.to_i / 100.0) %></td>
      </tr>
      <tr>
        <th>Valor do frete</th>
        <td><%= number_to_currency(@simulation.freight_cost_cents.to_i / 100.0) %></td>
      </tr>
    </tbody>
  </table>
</div>

<div class="total-box">
  <div class="label">Valor total</div>
  <div class="total-value"><%= number_to_currency(@simulation.total_cents.to_i / 100.0) %></div>
</div>

<div class="section">
  <div class="section-title">Observações</div>
  <div style="margin-top: 24px; page-break-inside: avoid;">
    <% if company.print_message_line_1.present? || company.print_message_line_2.present? %>
      <div style="margin-top: 24px; font-size: 14px;">
        <% if company.print_message_line_1.present? %>
          <p style="margin-bottom: 4px;"><%= company.print_message_line_1 %></p>
        <% end %>

        <% if company.print_message_line_2.present? %>
          <p style="margin-bottom: 4px;"><%= company.print_message_line_2 %></p>
        <% end %>
      </div>
    <% end %>
  </div>
  <% if @simulation.notes.present? %>
    <div><%= simple_format(@simulation.notes) %></div>
  <% end %>
</div>
