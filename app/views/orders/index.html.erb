<div class="max-w-5xl mx-auto">
  <div class="flex items-center justify-between">
    <div>
      <h1 class="text-2xl font-semibold text-gray-900 dark:text-gray-100">Pedidos</h1>
      <p class="mt-1 text-sm text-gray-500 dark:text-gray-400">
        Gerencie os pedidos cadastrados no sistema.
      </p>
    </div>

    <%= link_to "Novo pedido", new_order_path,
      class: "inline-flex items-center rounded-lg bg-indigo-600 px-4 py-2 text-sm font-medium text-white hover:bg-indigo-700" %>
  </div>

  <div class="overflow-hidden rounded-xl border border-gray-200 bg-white shadow-sm dark:border-gray-800 dark:bg-gray-900">
    <div class="overflow-x-auto">
      <table class="min-w-full divide-y divide-gray-200 dark:divide-gray-800">
        <thead class="bg-gray-50 dark:bg-gray-950">
          <tr>
            <th class="px-4 py-3 text-left text-xs font-semibold uppercase tracking-wider text-gray-500 dark:text-gray-400">
              Cliente
            </th>
            <th class="px-4 py-3 text-left text-xs font-semibold uppercase tracking-wider text-gray-500 dark:text-gray-400">
              Data
            </th>
            <th class="px-4 py-3 text-left text-xs font-semibold uppercase tracking-wider text-gray-500 dark:text-gray-400">
              Forma
            </th>
            <th class="px-4 py-3 text-left text-xs font-semibold uppercase tracking-wider text-gray-500 dark:text-gray-400">
              Condição
            </th>
            <th class="px-4 py-3 text-left text-xs font-semibold uppercase tracking-wider text-gray-500 dark:text-gray-400">
              Status
            </th>
            <th class="px-4 py-3 text-left text-xs font-semibold uppercase tracking-wider text-gray-500 dark:text-gray-400">
              Total
            </th>
            <th class="px-4 py-3 text-right text-xs font-semibold uppercase tracking-wider text-gray-500 dark:text-gray-400">
              Ações
            </th>
          </tr>
        </thead>

        <tbody class="divide-y divide-gray-200 dark:divide-gray-800">
          <% @orders.each do |order| %>
            <tr>
              <td class="px-4 py-3 text-sm text-gray-900 dark:text-gray-100">
                <%= order.customer&.name || "-" %>
              </td>
              <td class="px-4 py-3 text-sm text-gray-600 dark:text-gray-300">
                <%= l(order.occurred_on) %>
              </td>
              <td class="px-4 py-3 text-sm text-gray-600 dark:text-gray-300">
                <%= order.payment_method&.name || "-" %>
              </td>
              <td class="px-4 py-3 text-sm text-gray-600 dark:text-gray-300">
                <%= order.payment_term&.name || "-" %>
              </td>
              <td class="px-4 py-3 text-sm text-gray-600 dark:text-gray-300">
                <%= t("activerecord.attributes.order.statuses.#{order.status}") %>
              </td>
              <td class="px-4 py-3 text-sm text-gray-600 dark:text-gray-300">
                <%= number_to_currency(order.total_cents.to_i / 100.0, unit: "R$ ", separator: ",", delimiter: ".") %>
              </td>
              <td class="px-4 py-3 text-right text-sm">
                <div class="flex items-center justify-end gap-3">
                  <% if order.cancelable? %>
                    <%= button_to "Cancelar",
                      cancel_order_path(order),
                      method: :patch,
                      data: { turbo_confirm: "Tem certeza que deseja cancelar este pedido?" },
                      class: "px-3 py-1.5 rounded-lg bg-yellow-600 hover:bg-yellow-700 text-white transition" %>
                  <% end %>

                  <%= link_to "Editar", edit_order_path(order),
                    class: "text-indigo-600 hover:text-indigo-800 dark:text-indigo-400 dark:hover:text-indigo-300" %>

                  <%= link_to "Excluir", order_path(order),
                    data: { turbo_method: :delete, turbo_confirm: "Tem certeza que deseja excluir este pedido?" },
                    class: "text-red-600 hover:text-red-800 dark:text-red-400 dark:hover:text-red-300" %>
                </div>
              </td>
            </tr>
          <% end %>

          <% if @orders.empty? %>
            <tr>
              <td colspan="5" class="px-4 py-6 text-center text-sm text-gray-500 dark:text-gray-400">
                Nenhum pedido encontrado.
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>
</div>
