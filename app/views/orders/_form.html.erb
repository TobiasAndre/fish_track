<%= form_with model: @order, local: true do |form| %>
  <div class="space-y-6">
    <% if @order.errors.any? %>
      <div class="rounded-lg border border-red-300 bg-red-50 px-4 py-3 text-sm text-red-700 dark:border-red-800 dark:bg-red-950 dark:text-red-300">
        <p class="font-semibold mb-2">Não foi possível salvar o pedido:</p>
        <ul class="list-disc pl-5 space-y-1">
          <% @order.errors.full_messages.each do |message| %>
            <li><%= message %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <div class="grid grid-cols-1 gap-4 sm:grid-cols-2">
      <div>
        <%= form.label :customer_id, "Cliente", class: "block text-sm font-medium text-gray-700 dark:text-gray-300" %>
        <div class="mt-1">
          <%= form.collection_select :customer_id, @customers, :id, :name,
            { prompt: "Selecione um cliente" },
            class: "w-full rounded-lg border px-3 py-2 text-sm
                    bg-white dark:bg-gray-950
                    border-gray-300 dark:border-gray-700
                    text-gray-900 dark:text-gray-100
                    focus:outline-none focus:ring-2 focus:ring-indigo-500" %>
        </div>
      </div>

      <div>
        <%= form.label :status, "Status", class: "block text-sm font-medium text-gray-700 dark:text-gray-300" %>
        <div class="mt-1">
          <%= form.select :status,
            options_for_select(
              [
                ["Rascunho", "draft"],
                ["Confirmado", "confirmed"],
                ["Entregue", "delivered"],
                ["Cancelado", "canceled"]
              ],
              @order.status
            ),
            {},
            class: "w-full rounded-lg border px-3 py-2 text-sm
                    bg-white dark:bg-gray-950
                    border-gray-300 dark:border-gray-700
                    text-gray-900 dark:text-gray-100
                    focus:outline-none focus:ring-2 focus:ring-indigo-500" %>
        </div>
      </div>
    </div>

    <div class="grid grid-cols-1 gap-4 sm:grid-cols-2">
      <div>
        <%= form.label :occurred_on, "Data do pedido", class: "block text-sm font-medium text-gray-700 dark:text-gray-300" %>
        <div class="mt-1">
          <%= form.date_field :occurred_on,
            class: "w-full rounded-lg border px-3 py-2 text-sm
                    bg-white dark:bg-gray-950
                    border-gray-300 dark:border-gray-700
                    text-gray-900 dark:text-gray-100
                    focus:outline-none focus:ring-2 focus:ring-indigo-500" %>
        </div>
      </div>

      <div>
        <%= form.label :total_cents, "Valor total (centavos)", class: "block text-sm font-medium text-gray-700 dark:text-gray-300" %>
        <div class="mt-1">
          <%= form.number_field :total_cents,
            min: 0,
            step: 1,
            class: "w-full rounded-lg border px-3 py-2 text-sm
                    bg-white dark:bg-gray-950
                    border-gray-300 dark:border-gray-700
                    text-gray-900 dark:text-gray-100
                    focus:outline-none focus:ring-2 focus:ring-indigo-500" %>
        </div>
        <p class="mt-1 text-xs text-gray-500 dark:text-gray-400">
          Ex.: 150000 para R$ 1.500,00
        </p>
      </div>
    </div>

    <div>
      <%= form.label :notes, "Observações", class: "block text-sm font-medium text-gray-700 dark:text-gray-300" %>
      <div class="mt-1">
        <%= form.text_area :notes, rows: 4,
          class: "w-full rounded-lg border px-3 py-2 text-sm resize-none
                  bg-white dark:bg-gray-950
                  border-gray-300 dark:border-gray-700
                  text-gray-900 dark:text-gray-100
                  focus:outline-none focus:ring-2 focus:ring-indigo-500" %>
      </div>
    </div>

    <div class="flex items-center justify-end gap-4">
      <%= link_to "Cancelar", orders_path, class: "text-sm text-gray-500 hover:text-gray-700 dark:text-gray-400 dark:hover:text-gray-200" %>
      <%= form.submit @order.persisted? ? "Atualizar pedido" : "Criar pedido",
        class: "inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md shadow-sm text-white bg-indigo-600 hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500" %>
    </div>
  </div>
<% end %>
