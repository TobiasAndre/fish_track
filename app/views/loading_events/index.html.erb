<div class="max-w-5xl mx-auto space-y-4">
  <div class="flex flex-col gap-3">
    <div>
      <h1 class="text-xl font-semibold text-gray-900 dark:text-gray-100">
        Carregamento
      </h1>
    </div>

    <div class="w-full sm:max-w-sm">
      <%= form_with url: loading_events_path, method: :get, local: true do %>
        <label class="block text-xs font-medium text-gray-500 dark:text-gray-400 mb-1">
          Selecione o lote
        </label>

        <%= select_tag :batch_stocking_id,
          options_from_collection_for_select(
            @batch_stockings || [],
            :id,
            :display_name,
            @selected_batch_stocking&.id
          ),
          prompt: "Selecione um lote",
          onchange: "this.form.submit()",
          class: "w-full rounded-lg border px-3 py-2 text-sm
                  bg-white dark:bg-gray-950
                  border-gray-300 dark:border-gray-700
                  text-gray-900 dark:text-gray-100
                  focus:outline-none focus:ring-2 focus:ring-indigo-500" %>
      <% end %>
    </div>
  </div>

  <% if @selected_batch_stocking.present? %>
    <div class="flex flex-wrap gap-2">
      <% if @selected_batch_stocking.stocked_on.present? %>
        <span class="inline-flex items-center px-2 py-1 rounded-lg text-xs bg-gray-100 text-gray-800 dark:bg-gray-800 dark:text-gray-200">
          Alojamento:
          <span class="ml-1 font-medium"><%= l(@selected_batch_stocking.stocked_on) %></span>
        </span>
      <% end %>

      <% if @selected_batch_stocking.quantity.present? %>
        <span class="inline-flex items-center px-2 py-1 rounded-lg text-xs bg-gray-100 text-gray-800 dark:bg-gray-800 dark:text-gray-200">
          Qtd. alojada:
          <span class="ml-1 font-medium">
            <%= number_with_delimiter(@selected_batch_stocking.quantity, delimiter: ".") %>
          </span>
        </span>
      <% end %>

      <span class="inline-flex items-center px-2 py-1 rounded-lg text-xs bg-gray-100 text-gray-800 dark:bg-gray-800 dark:text-gray-200">
        Peso atual:
        <span class="ml-1 font-medium">
          <%= number_with_precision(@current_avg_weight_g.to_f, precision: 2, separator: ",", delimiter: ".") %>g
        </span>
      </span>

      <% fish_per_m2 = @selected_batch_stocking.quantity.to_f / ((@selected_batch_stocking.pond&.capacity || 1).to_f.nonzero? || 1) %>
      <span class="inline-flex items-center px-2 py-1 rounded-lg text-xs bg-gray-100 text-gray-800 dark:bg-gray-800 dark:text-gray-200">
        Peixes por m²:
        <span class="ml-1 font-medium">
          <%= number_with_precision(fish_per_m2, precision: 2, separator: ",", delimiter: ".") %>
        </span>
      </span>

      <% if @selected_batch_stocking.current_biomass_kg.present? %>
        <span class="inline-flex items-center px-2 py-1 rounded-lg text-xs bg-gray-100 text-gray-800 dark:bg-gray-800 dark:text-gray-200">
          Biomassa atual:
          <span class="ml-1 font-medium">
            <%= number_with_precision(@selected_batch_stocking.current_biomass_kg, precision: 2, separator: ",", delimiter: ".") %>kg
          </span>
        </span>
      <% end %>
    </div>

    <div class="rounded-xl border border-gray-200 dark:border-gray-800 bg-white dark:bg-gray-900 p-4">
      <div class="mb-3">
        <h2 class="text-sm font-semibold text-gray-800 dark:text-gray-100">
          Novo lançamento
        </h2>
      </div>

      <% if @stocking_event.errors.any? %>
        <div class="mb-4 rounded-lg border border-red-200 bg-red-50 px-3 py-2 text-sm text-red-700 dark:border-red-900 dark:bg-red-950 dark:text-red-300">
          <p class="font-medium mb-1">Não foi possível salvar:</p>
          <ul class="list-disc pl-5 space-y-1">
            <% @stocking_event.errors.full_messages.each do |message| %>
              <li><%= message %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <%= form_with model: @stocking_event,
        url: loading_events_path,
        local: true,
        data: { controller: "loading-form" },
        class: "space-y-4" do |f| %>

        <%= f.hidden_field :batch_stocking_id, value: @selected_batch_stocking.id %>

        <div class="grid grid-cols-1 sm:grid-cols-4 gap-4">
          <div>
            <%= f.label :occurred_on, "Data", class: "block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1" %>
            <%= f.date_field :occurred_on, required: true, class: "w-full rounded-lg border px-3 py-2 text-sm bg-white dark:bg-gray-950 border-gray-300 dark:border-gray-700 text-gray-900 dark:text-gray-100 focus:outline-none focus:ring-2 focus:ring-indigo-500" %>
          </div>

          <div>
            <%= f.label :customer_id, "Cliente", class: "block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1" %>
            <%= f.collection_select :customer_id, @customers || [], :id, :name,
              { prompt: "Selecione um cliente" },
              class: "w-full rounded-lg border px-3 py-2 text-sm bg-white dark:bg-gray-950 border-gray-300 dark:border-gray-700 text-gray-900 dark:text-gray-100 focus:outline-none focus:ring-2 focus:ring-indigo-500" %>
          </div>

          <div>
            <%= f.label :integrated_id, "Integrado", class: "block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1" %>
            <%= f.collection_select :integrated_id, @integrateds || [], :id, :name,
              { prompt: "Selecione um integrado" },
              class: "w-full rounded-lg border px-3 py-2 text-sm bg-white dark:bg-gray-950 border-gray-300 dark:border-gray-700 text-gray-900 dark:text-gray-100 focus:outline-none focus:ring-2 focus:ring-indigo-500" %>
          </div>

          <div>
            <%= f.label :payment_date, "Data de pagamento", class: "block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1" %>
            <%= f.date_field :payment_date, class: "w-full rounded-lg border px-3 py-2 text-sm bg-white dark:bg-gray-950 border-gray-300 dark:border-gray-700 text-gray-900 dark:text-gray-100 focus:outline-none focus:ring-2 focus:ring-indigo-500" %>
          </div>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
          <div>
            <%= f.label :total_weight_kg, "Peso total carregado (kg)", class: "block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1" %>
            <%= f.text_field :total_weight_kg,
              required: true,
              inputmode: "decimal",
              data: {
                "loading-form-target": "totalWeight",
                action: "input->loading-form#formatDecimalInput change->loading-form#recalculate"
              },
              class: "w-full rounded-lg border px-3 py-2 text-sm bg-white dark:bg-gray-950 border-gray-300 dark:border-gray-700 text-gray-900 dark:text-gray-100 focus:outline-none focus:ring-2 focus:ring-indigo-500" %>
          </div>

          <div>
            <%= f.label :avg_weight_g, "Peso médio (g)", class: "block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1" %>
            <%= f.text_field :avg_weight_g,
              required: true,
              inputmode: "decimal",
              value: number_with_precision(@current_avg_weight_g.to_f, precision: 2, separator: ",", delimiter: "."),
              data: {
                "loading-form-target": "avgWeight",
                action: "input->loading-form#formatDecimalInput change->loading-form#recalculate"
              },
              class: "w-full rounded-lg border px-3 py-2 text-sm bg-white dark:bg-gray-950 border-gray-300 dark:border-gray-700 text-gray-900 dark:text-gray-100 focus:outline-none focus:ring-2 focus:ring-indigo-500" %>
          </div>

          <div>
            <%= f.label :quantity, "Quantidade calculada", class: "block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1" %>
            <%= f.text_field :quantity,
              readonly: true,
              data: { "loading-form-target": "quantity" },
              class: "w-full rounded-lg border px-3 py-2 text-sm bg-gray-50 dark:bg-gray-900 border-gray-300 dark:border-gray-700 text-gray-900 dark:text-gray-100 focus:outline-none" %>
          </div>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
          <div>
            <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Preço por kg</label>
            <input type="text" inputmode="numeric" placeholder="R$ 0,00"
              value="<%= @stocking_event.price_per_kg_cents.to_i > 0 ? number_to_currency(@stocking_event.price_per_kg_cents.to_i / 100.0) : "" %>"
              data-action="input->loading-form#maskCurrency"
              data-loading-form-target="pricePerKg"
              class="w-full rounded-lg border px-3 py-2 text-sm bg-white dark:bg-gray-950 border-gray-300 dark:border-gray-700 text-gray-900 dark:text-gray-100 focus:outline-none focus:ring-2 focus:ring-indigo-500">

            <%= f.hidden_field :price_per_kg_cents, data: { "loading-form-target": "pricePerKgCents" } %>
          </div>

          <div>
            <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Milheiro</label>
            <input type="text" inputmode="numeric" placeholder="R$ 0,00"
              value="<%= @stocking_event.thousand_value_cents.to_i > 0 ? number_to_currency(@stocking_event.thousand_value_cents.to_i / 100.0) : "" %>"
              data-action="input->loading-form#maskCurrency"
              data-loading-form-target="thousandValue"
              class="w-full rounded-lg border px-3 py-2 text-sm bg-white dark:bg-gray-950 border-gray-300 dark:border-gray-700 text-gray-900 dark:text-gray-100 focus:outline-none focus:ring-2 focus:ring-indigo-500">

            <%= f.hidden_field :thousand_value_cents, data: { "loading-form-target": "thousandValueCents" } %>
          </div>

          <div>
            <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Valor do frete</label>
            <input type="text" inputmode="numeric" placeholder="R$ 0,00"
              value="<%= @stocking_event.freight_cost_cents.to_i > 0 ? number_to_currency(@stocking_event.freight_cost_cents.to_i / 100.0) : "" %>"
              data-action="input->loading-form#maskCurrency"
              data-loading-form-target="freightCost"
              class="w-full rounded-lg border px-3 py-2 text-sm bg-white dark:bg-gray-950 border-gray-300 dark:border-gray-700 text-gray-900 dark:text-gray-100 focus:outline-none focus:ring-2 focus:ring-indigo-500">

            <%= f.hidden_field :freight_cost_cents, data: { "loading-form-target": "freightCostCents" } %>
          </div>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          <div>
            <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Valor do carregamento</label>
            <input type="text" inputmode="numeric" placeholder="R$ 0,00"
              value="<%= @stocking_event.loading_cost_cents.to_i > 0 ? number_to_currency(@stocking_event.loading_cost_cents.to_i / 100.0) : "" %>"
              data-action="input->loading-form#maskCurrency"
              data-loading-form-target="loadingCost"
              class="w-full rounded-lg border px-3 py-2 text-sm bg-white dark:bg-gray-950 border-gray-300 dark:border-gray-700 text-gray-900 dark:text-gray-100 focus:outline-none focus:ring-2 focus:ring-indigo-500">

            <%= f.hidden_field :loading_cost_cents, data: { "loading-form-target": "loadingCostCents" } %>
          </div>

          <div>
            <%= f.label :payment_method_id, "Forma de pagamento", class: "block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1" %>
            <%= f.collection_select :payment_method_id, @payment_methods || [], :id, :name,
              { prompt: "Selecione a forma de pagamento" },
              class: "w-full rounded-lg border px-3 py-2 text-sm bg-white dark:bg-gray-950 border-gray-300 dark:border-gray-700 text-gray-900 dark:text-gray-100 focus:outline-none focus:ring-2 focus:ring-indigo-500" %>
          </div>
        </div>

        <div>
          <%= f.label :notes, "Observações", class: "block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1" %>
          <%= f.text_area :notes, rows: 1, class: "w-full rounded-lg border px-3 py-2 text-sm bg-white dark:bg-gray-950 border-gray-300 dark:border-gray-700 text-gray-900 dark:text-gray-100 focus:outline-none focus:ring-2 focus:ring-indigo-500 resize-none" %>
        </div>

        <div class="flex justify-end pt-1">
          <%= f.submit "Salvar carregamento", class: "inline-flex items-center justify-center px-4 py-2 rounded-lg bg-indigo-600 hover:bg-indigo-700 text-white text-sm font-medium transition" %>
        </div>
      <% end %>
    </div>

    <div class="rounded-xl border border-gray-200 dark:border-gray-800 bg-white dark:bg-gray-900 p-4">
      <div class="mb-3 flex items-center justify-between">
        <h2 class="text-sm font-semibold text-gray-800 dark:text-gray-100">
          Histórico
        </h2>

        <span class="text-xs text-gray-500 dark:text-gray-400">
          <%= @events.count %> registro(s)
        </span>
      </div>

      <% if @events.any? %>
        <div class="overflow-x-auto">
          <table class="min-w-full text-sm">
            <thead>
              <tr class="border-b border-gray-200 dark:border-gray-800 text-left text-gray-500 dark:text-gray-400">
                <th class="py-2 pr-4 font-medium">Data</th>
                <th class="py-2 pr-4 font-medium">Cliente</th>
                <th class="py-2 pr-4 font-medium">Integrado</th>
                <th class="py-2 pr-4 font-medium">Quantidade</th>
                <th class="py-2 pr-4 font-medium">Peso total</th>
                <th class="py-2 pr-4 font-medium">Peso médio</th>
                <th class="py-2 pr-4 font-medium">Preço/kg</th>
                <th class="py-2 pr-4 font-medium">Pagamento</th>
              </tr>
            </thead>

            <tbody>
              <% @events.each do |event| %>
                <% avg = event.avg_weight_g.presence || (event.quantity.to_f.positive? ? (event.total_weight_kg.to_f * 1000 / event.quantity.to_f) : nil) %>

                <tr class="border-b border-gray-100 dark:border-gray-800">
                  <td class="py-2 pr-4">
                    <%= event.occurred_on.present? ? l(event.occurred_on) : "—" %>
                  </td>

                  <td class="py-2 pr-4">
                    <%= event.customer&.name || "—" %>
                  </td>

                  <td class="py-2 pr-4">
                    <%= event.integrated&.name || "—" %>
                  </td>

                  <td class="py-2 pr-4">
                    <%= event.quantity.present? ? number_with_delimiter(event.quantity, delimiter: ".") : "—" %>
                  </td>

                  <td class="py-2 pr-4">
                    <%= event.total_weight_kg.present? ? "#{number_with_precision(event.total_weight_kg, precision: 3, separator: ",", delimiter: ".")}kg" : "—" %>
                  </td>

                  <td class="py-2 pr-4">
                    <%= avg.present? ? "#{number_with_precision(avg, precision: 2, separator: ",", delimiter: ".")}g" : "—" %>
                  </td>

                  <td class="py-2 pr-4">
                    <%= event.price_per_kg_cents.to_i.positive? ? number_to_currency(event.price_per_kg_cents.to_i / 100.0) : "—" %>
                  </td>

                  <td class="py-2 pr-4">
                    <%= event.payment_method&.name || "—" %>
                  </td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      <% else %>
        <div class="text-center py-6">
          <p class="text-sm text-gray-500 dark:text-gray-400">
            Nenhum carregamento registrado para este lote.
          </p>
        </div>
      <% end %>
    </div>
  <% else %>
    <div class="rounded-xl border border-dashed border-gray-300 dark:border-gray-700 bg-white dark:bg-gray-900 p-6 text-center">
      <p class="text-sm text-gray-500 dark:text-gray-400">
        Selecione um lote para visualizar o formulário e o histórico.
      </p>
    </div>
  <% end %>
</div>
