          <span>🏷️</span><span data-sidebar-target="label">Produtos</span>
        <% end %>

        <%= link_to payment_terms_path, class: "flex items-center gap-3 px-3 py-2 rounded-lg hover:bg-gray-100 dark:hover:bg-gray-800 #{controller_name == 'payment_terms' ? selected_menu : unselected_menu}" do %>
          <span>📄</span><span data-sidebar-target="label">Condições de pagamento</span>
        <% end %>

        <%= link_to payment_methods_path, class: "flex items-center gap-3 px-3 py-2 rounded-lg hover:bg-gray-100 dark:hover:bg-gray-800 #{controller_name == 'payment_methods' ? selected_menu : unselected_menu}" do %>
          <span>💳</span><span data-sidebar-target="label">Formas de pagamento</span>
        <% end %>

        <%= link_to employees_path, class: "flex items-center gap-3 px-3 py-2 rounded-lg hover:bg-gray-100 dark:hover:bg-gray-800 #{controller_name == 'employees' ? selected_menu : unselected_menu}" do %>
          <span>👥</span><span data-sidebar-target="label">Funcionários</span>
        <% end %>
      </div>
    </details>

    <!-- Lançamentos -->
    <p class="px-3 pt-3 pb-1 text-xs font-semibold uppercase tracking-wider text-gray-400 dark:text-gray-500"
      data-sidebar-target="label">
      Lançamentos
