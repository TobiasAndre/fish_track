    <%= link_to batches_path, class: "flex items-center gap-3 px-3 py-2 rounded-lg hover:bg-gray-100 dark:hover:bg-gray-800 #{controller_name == 'batches' ? selected_menu : unselected_menu}" do %>
      <span>📦</span><span data-sidebar-target="label">Lotes</span>
