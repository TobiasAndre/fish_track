<!-- ========================================================= -->
<!-- Mobile overlay + drawer -->
<!-- ========================================================= -->
<%
  cadastro_controllers = %w[
    units
    ponds
    suppliers
    customers
    products
    payment_terms
    payment_methods
    employees
  ]

  lancamento_controllers = %w[
    batches
    payroll
    financial_entries
    orders
    simulations
  ]

  admin_controllers = %w[
    admin_users
    admin_companies
  ]

  cadastros_open = cadastro_controllers.include?(controller_name)
  selected_menu = 'bg-indigo-50 text-indigo-700 dark:bg-indigo-950 dark:text-indigo-300'
  unselected_menu = 'hover:bg-gray-100 dark:hover:bg-gray-800'
%>
<div
  data-sidebar-target="overlay"
  class="hidden lg:hidden fixed inset-0 z-50"
  role="dialog"
  aria-modal="true"
  aria-label="Mobile navigation"
>
  <!-- Backdrop -->
  <button
    type="button"
    class="absolute inset-0 bg-black/50 opacity-0 transition-opacity duration-200
           data-[open=true]:opacity-100"
    data-action="click->sidebar#closeMobile"
    aria-label="Close menu"
  ></button>

  <!-- Drawer -->
  <aside
    data-sidebar-target="mobileDrawer"
    data-open="false"
    class="absolute left-0 top-0 h-full
           w-[85vw] max-w-xs
           bg-white dark:bg-gray-900
           border-r border-gray-200 dark:border-gray-800
           shadow-2xl
           -translate-x-full transition-transform duration-200 ease-out
           data-[open=true]:translate-x-0
           flex flex-col
           pt-[env(safe-area-inset-top)] pb-[env(safe-area-inset-bottom)]"
  >
    <!-- Header -->
    <div class="px-4 h-16 flex items-center justify-between border-b border-gray-200 dark:border-gray-800">
      <span class="font-semibold text-gray-800 dark:text-gray-100">Fish Track</span>

      <button
        type="button"
        class="p-2 rounded-lg hover:bg-gray-100 dark:hover:bg-gray-800 transition"
        data-action="click->sidebar#closeMobile"
        aria-label="Close menu"
      >
        ✕
      </button>
    </div>

    <!-- Navigation -->
    <nav class="p-3 space-y-1 overflow-y-auto flex-1 overscroll-contain">
      <%= link_to root_path, class: "flex items-center gap-3 px-3 py-2 rounded-lg hover:bg-gray-100 dark:hover:bg-gray-800" do %>
        <span>📊</span><span class="text-sm font-medium">Dashboard</span>
      <% end %>

      <!-- Cadastros -->
      <details 
        class="group rounded-lg"
        data-controller="menu-group"
        data-menu-group-open-value="<%= cadastros_open %>">
        <summary class="flex items-center justify-between px-3 py-2 rounded-lg cursor-pointer list-none hover:bg-gray-100 dark:hover:bg-gray-800 text-sm font-medium text-gray-800 dark:text-gray-100">
          <span class="flex items-center gap-3">
            <span>🗂️</span>
            <span data-sidebar-target="label">Cadastros</span>
          </span>

          <span class="flex items-center justify-center w-5 h-5" data-sidebar-target="label">
            <svg
              class="w-4 h-4 transition-transform group-open:rotate-180"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              viewBox="0 0 24 24"
            >
              <path stroke-linecap="round" stroke-linejoin="round" d="M6 9l6 6 6-6" />
            </svg>
          </span>
        </summary>

        <div class="mt-1 ml-3 pl-3 border-l border-gray-200 dark:border-gray-700 space-y-1">
          <%= link_to units_path, class: "flex items-center gap-3 px-3 py-2 rounded-lg hover:bg-gray-100 dark:hover:bg-gray-800 #{controller_name == 'units' ? selected_menu : unselected_menu}" do %>
            <span>📍</span><span class="text-sm font-medium">Unidades</span>
          <% end %>

          <%= link_to ponds_path, class: "flex items-center gap-3 px-3 py-2 rounded-lg hover:bg-gray-100 dark:hover:bg-gray-800 #{controller_name == 'ponds' ? selected_menu : unselected_menu}" do %>
            <span>💧</span><span class="text-sm font-medium">Tanques</span>
          <% end %>

          <%= link_to suppliers_path, class: "flex items-center gap-3 px-3 py-2 rounded-lg hover:bg-gray-100 dark:hover:bg-gray-800 #{controller_name == 'suppliers' ? selected_menu : unselected_menu}" do %>
            <span>🏭</span><span class="text-sm font-medium">Fornecedores</span>
          <% end %>

          <%= link_to customers_path, class: "flex items-center gap-3 px-3 py-2 rounded-lg hover:bg-gray-100 dark:hover:bg-gray-800 #{controller_name == 'customers' ? selected_menu : unselected_menu}" do %>
            <span>🤝</span><span class="text-sm font-medium">Clientes</span>
          <% end %>

          <%= link_to products_path, class: "flex items-center gap-3 px-3 py-2 rounded-lg hover:bg-gray-100 dark:hover:bg-gray-800 #{controller_name == 'products' ? selected_menu : unselected_menu}" do %>
            <span>🏷️</span><span class="text-sm font-medium">Produtos</span>
          <% end %>

          <%= link_to payment_terms_path, class: "flex items-center gap-3 px-3 py-2 rounded-lg hover:bg-gray-100 dark:hover:bg-gray-800 #{controller_name == 'payment_terms' ? selected_menu : unselected_menu}" do %>
            <span>📄</span><span class="text-sm font-medium">Condições de pagamento</span>
          <% end %>

          <%= link_to payment_methods_path, class: "flex items-center gap-3 px-3 py-2 rounded-lg hover:bg-gray-100 dark:hover:bg-gray-800 #{controller_name == 'payment_methods' ? selected_menu : unselected_menu}" do %>
            <span>💳</span><span class="text-sm font-medium">Formas de pagamento</span>
          <% end %>

          <%= link_to employees_path, class: "flex items-center gap-3 px-3 py-2 rounded-lg hover:bg-gray-100 dark:hover:bg-gray-800 #{controller_name == 'employees' ? selected_menu : unselected_menu}" do %>
            <span>👥</span><span class="text-sm font-medium">Funcionários</span>
          <% end %>
        </div>
      </details>

      <!-- Lançamentos -->
      <p class="px-3 pt-3 pb-1 text-xs font-semibold uppercase tracking-wider text-gray-400 dark:text-gray-500">
        Lançamentos
      </p>

      <%= link_to batches_path, class: "flex items-center gap-3 px-3 py-2 rounded-lg hover:bg-gray-100 dark:hover:bg-gray-800 #{controller_name == 'batches' ? selected_menu : unselected_menu}" do %>
        <span>📦</span><span class="text-sm font-medium">Lotes</span>
      <% end %>

      <%= link_to payroll_path, class: "flex items-center gap-3 px-3 py-2 rounded-lg hover:bg-gray-100 dark:hover:bg-gray-800 #{controller_name == 'payroll' ? selected_menu : unselected_menu}" do %>
        <span>🧾</span><span class="text-sm font-medium">Folha</span>
      <% end %>

      <%= link_to financial_entries_path, class: "flex items-center gap-3 px-3 py-2 rounded-lg hover:bg-gray-100 dark:hover:bg-gray-800 #{controller_name == 'financial_entries' ? selected_menu : unselected_menu}" do %>
        <span>💰</span><span class="text-sm font-medium">Financeiro</span>
      <% end %>

      <%= link_to orders_path, class: "flex items-center gap-3 px-3 py-2 rounded-lg hover:bg-gray-100 dark:hover:bg-gray-800 #{controller_name == 'orders' ? selected_menu : unselected_menu}" do %>
        <span>📋</span><span class="text-sm font-medium">Pedidos</span>
      <% end %>

      <%= link_to simulations_path, class: "flex items-center gap-3 px-3 py-2 rounded-lg hover:bg-gray-100 dark:hover:bg-gray-800 #{controller_name == 'simulations' ? selected_menu : unselected_menu}" do %>
        <span>🧮</span><span class="text-sm font-medium">Orçamentos</span>
      <% end %>

      <% if system_admin? %>
        <div class="my-3 border-t border-gray-200 dark:border-gray-800"></div>

        <p class="px-3 py-1 text-xs font-semibold uppercase tracking-wider text-gray-400 dark:text-gray-500">
          Administração
        </p>

        <%= link_to admin_users_path, class: "flex items-center gap-3 px-3 py-2 rounded-lg hover:bg-gray-100 dark:hover:bg-gray-800 #{controller_name == 'admin_users' ? selected_menu : unselected_menu}" do %>
          <span>👤</span>
          <span class="text-sm font-medium">Usuários</span>
        <% end %>

        <%= link_to admin_companies_path, class: "flex items-center gap-3 px-3 py-2 rounded-lg hover:bg-gray-100 dark:hover:bg-gray-800 #{controller_name == 'admin_companies' ? selected_menu : unselected_menu}" do %>
          <span>🏢</span>
          <span class="text-sm font-medium">Empresas</span>
        <% end %>
      <% end %>
    </nav>

    <!-- Footer -->
    <div class="p-3 border-t border-gray-200 dark:border-gray-800">
      <%= button_to destroy_user_session_path, method: :delete,
        class: "w-full flex items-center gap-3 px-3 py-2 rounded-lg text-left text-red-600 dark:text-red-400 hover:bg-red-50 dark:hover:bg-red-950" do %>
        <span>🚪</span><span class="text-sm font-medium">Logout</span>
      <% end %>
    </div>
  </aside>
</div>

<!-- ========================================================= -->
<!-- Desktop sidebar -->
