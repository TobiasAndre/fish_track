      <%= link_to admin_companies_path, class: "flex items-center gap-3 px-3 py-2 rounded-lg hover:bg-gray-100 dark:hover:bg-gray-800 #{controller_name == 'admin_companies' ? selected_menu : unselected_menu}" do %>
