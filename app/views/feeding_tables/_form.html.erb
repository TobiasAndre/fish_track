<div class="space-y-6">
  <div>
    <h1 class="text-2xl font-bold text-gray-900 dark:text-white">
      Nova Tabela de Arraçoamento
    </h1>

    <p class="text-sm text-gray-600 dark:text-gray-400">
      Selecione a faixa de peso, a faixa de temperatura e informe o percentual.
    </p>
  </div>

  <%= form_with model: feeding_table, class: "space-y-6" do |form| %>
    <div class="rounded-xl border border-gray-200 bg-white p-5 shadow-sm dark:border-gray-700 dark:bg-gray-800">
      <div class="grid grid-cols-1 gap-4 md:grid-cols-2">
        <div>
          <%= form.label :name, "Nome", class: "block text-sm font-medium text-gray-700 dark:text-gray-300" %>
          <%= form.text_field :name, class: "mt-1 w-full rounded-lg border-gray-300 dark:border-gray-700 dark:bg-gray-900 dark:text-white" %>
        </div>

        <div>
          <%= form.label :description, "Descrição", class: "block text-sm font-medium text-gray-700 dark:text-gray-300" %>
          <%= form.text_field :description, class: "mt-1 w-full rounded-lg border-gray-300 dark:border-gray-700 dark:bg-gray-900 dark:text-white" %>
        </div>
      </div>
    </div>

    <div class="rounded-xl border border-gray-200 bg-white p-5 shadow-sm dark:border-gray-700 dark:bg-gray-800">
      <h2 class="mb-4 text-lg font-semibold text-gray-900 dark:text-white">
        Percentuais de arraçoamento
      </h2>

      <div class="overflow-x-auto">
        <table class="min-w-full text-sm">
          <thead class="bg-gray-50 dark:bg-gray-900">
            <tr>
              <th class="px-3 py-2 text-left text-gray-600 dark:text-gray-300">Faixa de peso</th>
              <th class="px-3 py-2 text-left text-gray-600 dark:text-gray-300">Faixa de temperatura</th>
              <th class="px-3 py-2 text-left text-gray-600 dark:text-gray-300">% Ração</th>
              <th class="px-3 py-2 text-center text-gray-600 dark:text-gray-300">Remover</th>
            </tr>
          </thead>

          <tbody>
            <%= form.fields_for :feeding_strategy_items do |item_form| %>
              <tr class="border-t border-gray-200 dark:border-gray-700">
                <td class="px-3 py-2">
                  <%= item_form.collection_select(
                        :feeding_weight_range_id,
                        @weight_ranges,
                        :id,
                        ->(range) { "#{range.weight_from}g até #{range.weight_to}g" },
                        { prompt: "Selecione o peso" },
                        class: "w-full rounded-lg border px-3 py-2 text-sm
                                bg-white dark:bg-gray-950
                                border-gray-300 dark:border-gray-700
                                text-gray-900 dark:text-gray-100
                                focus:outline-none focus:ring-2 focus:ring-indigo-500"
                      ) %>
                </td>

                <td class="px-3 py-2">
                  <%= item_form.collection_select(
                        :feeding_temperature_range_id,
                        @temperature_ranges,
                        :id,
                        ->(range) { "#{range.temperature_from}°C até #{range.temperature_to}°C" },
                        { prompt: "Selecione a temperatura" },
                        class: "w-full rounded-lg border px-3 py-2 text-sm
                                bg-white dark:bg-gray-950
                                border-gray-300 dark:border-gray-700
                                text-gray-900 dark:text-gray-100
                                focus:outline-none focus:ring-2 focus:ring-indigo-500"
                      ) %>
                </td>

                <td class="px-3 py-2">
                  <%= item_form.number_field :feeding_percentage,
                        step: 0.01,
                        class: "w-full rounded-lg border px-3 py-2 text-sm bg-white dark:bg-gray-950 border-gray-300 dark:border-gray-700 text-gray-900 dark:text-gray-100 focus:outline-none focus:ring-2 focus:ring-indigo-500",
                        placeholder: "Ex: 3.5" %>
                </td>

                <td class="px-3 py-2 text-center">
                  <%= item_form.check_box :_destroy %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </div>

    <div class="flex justify-end gap-3">
      <%= link_to "Cancelar",
            feeding_tables_path,
            class: "rounded-lg bg-gray-200 px-4 py-2 text-gray-800 hover:bg-gray-300 dark:bg-gray-700 dark:text-gray-100" %>

      <%= form.submit "Salvar",
            class: "rounded-lg bg-indigo-600 px-4 py-2 text-white hover:bg-indigo-700" %>
    </div>
  <% end %>
</div>