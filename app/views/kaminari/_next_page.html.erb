<% if current_page.last? %>
  <span class="inline-flex items-center justify-center rounded-lg px-3 py-2 text-sm font-medium text-gray-300 dark:text-gray-600">
    Próxima
  </span>
<% else %>
  <%= link_to url, rel: 'next', remote: remote,
    class: "inline-flex items-center justify-center rounded-lg px-3 py-2 text-sm font-medium text-gray-700 hover:bg-gray-100 dark:text-gray-200 dark:hover:bg-gray-800" do %>
    Próxima
  <% end %>
<% end %>
