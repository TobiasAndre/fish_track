<%= form_with(
  model: @stocking_event,
  url: @stocking_event.persisted? ?
    batch_batch_stocking_stocking_event_path(@batch, @batch_stocking, @stocking_event) :
    batch_batch_stocking_stocking_events_path(@batch, @batch_stocking),
  data: { controller: "batch-event-form" },
  class: "mt-6 space-y-4"
) do |f| %>

  <%= render "shared/form_errors", resource: @stocking_event %>

  <%= hidden_field_tag :previous_biomass,
    @previous_biomass,
    data: { "batch-event-form-target": "previousBiomass" } %>

  <%= hidden_field_tag :previous_avg_weight,
    @previous_avg_weight,
    data: { "batch-event-form-target": "previousAvgWeight" } %>

  <%= hidden_field_tag :previous_occurred_on,
    @previous_occurred_on,
    data: { "batch-event-form-target": "previousOccurredOn" } %>

  <%= hidden_field_tag :current_avg_weight_g,
    @current_avg_weight_g,
    data: { "batch-event-form-target": "currentAvgWeight" } %>

  <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
    <div>
      <%= f.label :event_type, "Tipo", class: "block text-sm font-medium text-gray-700 dark:text-gray-200 mb-1" %>
      <%= f.select :event_type,
        StockingEvent.event_types.keys.map { |k| [enum_t(StockingEvent.new(event_type: k), :event_type), k] },
        {},
        data: { "batch-event-form-target": "type", action: "change->batch-event-form#toggle" },
        class: "w-full rounded-lg border px-3 py-2 text-sm
                bg-white dark:bg-gray-950
                border-gray-300 dark:border-gray-700
                text-gray-900 dark:text-gray-100
                focus:outline-none focus:ring-2 focus:ring-indigo-500" %>
    </div>

    <div>
      <%= f.label :occurred_on, "Data", class: "block text-sm font-medium text-gray-700 dark:text-gray-200 mb-1" %>
      <%= f.date_field :occurred_on,
        data: { "batch-event-form-target": "occurredOn", action: "change->batch-event-form#recalculate" },
        class: "w-full rounded-lg border px-3 py-2 text-sm
                bg-white dark:bg-gray-950
                border-gray-300 dark:border-gray-700
                text-gray-900 dark:text-gray-100
                focus:outline-none focus:ring-2 focus:ring-indigo-500" %>
    </div>
  </div>

  <div data-batch-event-form-target="biometryRow" class="hidden space-y-4">
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
      <div>
        <%= f.label :volume, "Volume", class: "block text-sm font-medium text-gray-700 dark:text-gray-200 mb-1" %>
        <%= f.text_field :volume,
          inputmode: "numeric",
          data: { "batch-event-form-target": "volume", action: "input->batch-event-form#formatIntegerInput" },
          class: "w-full rounded-lg border px-3 py-2 text-sm
                  bg-white dark:bg-gray-950
                  border-gray-300 dark:border-gray-700
                  text-gray-900 dark:text-gray-100
                  focus:outline-none focus:ring-2 focus:ring-indigo-500" %>
      </div>

      <div>
        <%= f.label :quantity, "Quantidade", class: "block text-sm font-medium text-gray-700 dark:text-gray-200 mb-1" %>
        <%= f.text_field :quantity,
          inputmode: "numeric",
          data: { "batch-event-form-target": "quantity", action: "input->batch-event-form#formatIntegerInput change->batch-event-form#recalculate" },
          class: "w-full rounded-lg border px-3 py-2 text-sm
                  bg-white dark:bg-gray-950
                  border-gray-300 dark:border-gray-700
                  text-gray-900 dark:text-gray-100
                  focus:outline-none focus:ring-2 focus:ring-indigo-500" %>
      </div>

      <div>
        <%= f.label :total_weight_kg, "Peso (kg)", class: "block text-sm font-medium text-gray-700 dark:text-gray-200 mb-1" %>
        <%= f.text_field :total_weight_kg,
          inputmode: "decimal",
          data: { "batch-event-form-target": "totalWeight", action: "input->batch-event-form#formatDecimalInput change->batch-event-form#recalculate" },
          class: "w-full rounded-lg border px-3 py-2 text-sm
                  bg-white dark:bg-gray-950
                  border-gray-300 dark:border-gray-700
                  text-gray-900 dark:text-gray-100
                  focus:outline-none focus:ring-2 focus:ring-indigo-500" %>
      </div>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-4 gap-4">
      <div>
        <%= f.label :avg_weight_g, "Peso médio (g)", class: "block text-sm font-medium text-gray-700 dark:text-gray-200 mb-1" %>
        <%= f.text_field :avg_weight_g,
          readonly: true,
          data: { "batch-event-form-target": "avgWeight" },
          class: "w-full rounded-lg border px-3 py-2 text-sm
                  bg-gray-50 dark:bg-gray-900
                  border-gray-300 dark:border-gray-700
                  text-gray-900 dark:text-gray-100
                  focus:outline-none" %>
      </div>

      <div>
        <%= f.label :biomass, "Biomassa", class: "block text-sm font-medium text-gray-700 dark:text-gray-200 mb-1" %>
        <%= f.text_field :biomass,
          readonly: true,
          data: { "batch-event-form-target": "biomass" },
          class: "w-full rounded-lg border px-3 py-2 text-sm
                  bg-gray-50 dark:bg-gray-900
                  border-gray-300 dark:border-gray-700
                  text-gray-900 dark:text-gray-100
                  focus:outline-none" %>
      </div>

      <div>
        <%= f.label :weight_gain_kg, "Ganho de peso (kg)", class: "block text-sm font-medium text-gray-700 dark:text-gray-200 mb-1" %>
        <%= f.text_field :weight_gain_kg,
          readonly: true,
          data: { "batch-event-form-target": "weightGain" },
          class: "w-full rounded-lg border px-3 py-2 text-sm
                  bg-gray-50 dark:bg-gray-900
                  border-gray-300 dark:border-gray-700
                  text-gray-900 dark:text-gray-100
                  focus:outline-none" %>
      </div>

      <div>
        <%= f.label :gpd, "GPD", class: "block text-sm font-medium text-gray-700 dark:text-gray-200 mb-1" %>
        <%= f.text_field :gpd,
          readonly: true,
          data: { "batch-event-form-target": "gpd" },
          class: "w-full rounded-lg border px-3 py-2 text-sm
                  bg-gray-50 dark:bg-gray-900
                  border-gray-300 dark:border-gray-700
                  text-gray-900 dark:text-gray-100
                  focus:outline-none" %>
      </div>
    </div>
  </div>

  <div data-batch-event-form-target="mortalityRow" class="hidden space-y-4">
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
      <div>
        <%= f.label :quantity, "Quantidade", class: "block text-sm font-medium text-gray-700 dark:text-gray-200 mb-1" %>
        <%= f.text_field :quantity,
          inputmode: "numeric",
          data: { "batch-event-form-target": "mortalityQuantity", action: "input->batch-event-form#formatMortalityQuantityInput" },
          class: "w-full rounded-lg border px-3 py-2 text-sm
                  bg-white dark:bg-gray-950
                  border-gray-300 dark:border-gray-700
                  text-gray-900 dark:text-gray-100
                  focus:outline-none focus:ring-2 focus:ring-indigo-500" %>
      </div>

      <div>
        <%= f.label :avg_weight_g, "Peso médio usado (g)", class: "block text-sm font-medium text-gray-700 dark:text-gray-200 mb-1" %>
        <%= f.text_field :avg_weight_g,
          readonly: true,
          data: { "batch-event-form-target": "mortalityAvgWeight" },
          class: "w-full rounded-lg border px-3 py-2 text-sm
                  bg-gray-50 dark:bg-gray-900
                  border-gray-300 dark:border-gray-700
                  text-gray-900 dark:text-gray-100
                  focus:outline-none" %>
      </div>

      <div>
        <%= f.label :total_weight_kg, "Peso perdido (kg)", class: "block text-sm font-medium text-gray-700 dark:text-gray-200 mb-1" %>
        <%= f.text_field :total_weight_kg,
          readonly: true,
          data: { "batch-event-form-target": "mortalityWeightLoss" },
          class: "w-full rounded-lg border px-3 py-2 text-sm
                  bg-gray-50 dark:bg-gray-900
                  border-gray-300 dark:border-gray-700
                  text-gray-900 dark:text-gray-100
                  focus:outline-none" %>
      </div>
    </div>

    <div class="rounded-lg border border-amber-200 bg-amber-50 px-4 py-3 text-sm text-amber-800 dark:border-amber-900 dark:bg-amber-950/40 dark:text-amber-200">
      Este lançamento vai descontar a quantidade informada e o peso correspondente do saldo atual do tanque.
    </div>
  </div>

  <div data-batch-event-form-target="feedKgRow" class="hidden">
    <%= f.label :feed_kg, "Ração (kg)", class: "block text-sm font-medium text-gray-700 dark:text-gray-200 mb-1" %>
    <%= f.number_field :feed_kg, step: 0.001,
      class: "w-full rounded-lg border px-3 py-2 text-sm
              bg-white dark:bg-gray-950
              border-gray-300 dark:border-gray-700
              text-gray-900 dark:text-gray-100
              focus:outline-none focus:ring-2 focus:ring-indigo-500" %>
  </div>

  <div>
    <%= f.label :notes, "Observações (opcional)", class: "block text-sm font-medium text-gray-700 dark:text-gray-200 mb-1" %>
    <%= f.text_area :notes, rows: 3,
      class: "w-full rounded-lg border px-3 py-2 text-sm
              bg-white dark:bg-gray-950
              border-gray-300 dark:border-gray-700
              text-gray-900 dark:text-gray-100
              focus:outline-none focus:ring-2 focus:ring-indigo-500" %>
  </div>

  <div class="flex gap-2">
    <%= f.submit "Salvar",
      class: "flex-1 bg-indigo-600 hover:bg-indigo-700
              dark:bg-indigo-500 dark:hover:bg-indigo-400
              text-white font-medium py-2.5 rounded-lg transition" %>

    <%= link_to "Cancelar", batch_batch_stocking_stocking_events_path(@batch, @batch_stocking),
      class: "px-4 py-2.5 rounded-lg border border-gray-300 dark:border-gray-700
              hover:bg-gray-50 dark:hover:bg-gray-800 transition" %>
  </div>
<% end %>
